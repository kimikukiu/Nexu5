# WHOAMISEC QUANTUM INTELLIGENCE ULTRA - Environment Configuration

# Primary AI Provider (Google Gemini)
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Other AI Providers (Used via Proxy)
# These can also be set via the UI in the "API INPUT" section
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Server Configuration
PORT=3000
NODE_ENV=production

# Android/Mobile Build Config (If using Capacitor/Cordova)
# The App URL where the server is hosted
VITE_APP_URL=https://your-deployed-app.com
